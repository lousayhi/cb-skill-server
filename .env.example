# Skills server configuration (copy to .env and adjust)
# Comma-separated API keys. Clients use these as Bearer token / X-API-Key.
API_KEYS=team-key-1,team-key-2

# Git webhook shared secret (validated via X-Webhook-Secret header)
WEBHOOK_SECRET=change-me-to-a-strong-secret

# Sandbox runner limits for script-type skills
RUNNER_DEFAULT_IMAGE=python:3.12-slim
RUNNER_MEMORY=128m
RUNNER_CPUS=0.5
RUNNER_PIDS_LIMIT=64
RUNNER_TIMEOUT=30
RUNNER_NETWORK=false

LOG_LEVEL=INFO
